# ── Python ──
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.pytest_cache/

# ── Virtual environments ──
.venv/
venv/
env/

# ── Uploaded / generated assets ──
uploads/*
!uploads/.gitkeep

# ── User-uploaded custom workflows (keep curated ones tracked manually) ──
workflows/*
!workflows/.gitkeep
!workflows/sd15_depth.json

# ── OS / editor cruft ──
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp

# ── Logs ──
*.log

# ── Source media (keep the lightweight docs/demo.gif, not the raw MP4) ──
demo_Git.mp4
*.mp4
*.m4v
_images/
